# API Configuration
PORT=8000
HOST=0.0.0.0
DEBUG=False
DB_PATH=./Database/leads.db

# REQUIRED — Generate a secure random key. 
# You can generate one with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=sua_chave_secreta_aqui_para_producao_gerada

# Databricks Configuration (Opcional - deixe como está se não for usar)
DATABRICKS_HOST=https://your-databricks-instance.cloud.databricks.com
DATABRICKS_TOKEN=dapi...
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/...

# Meta / Facebook CRM Configuration (Opcional - deixe como está se não for usar)
META_ACCESS_TOKEN=EAAB...
META_CRM_PAGE_ID=1234567890
META_APP_SECRET=your_app_secret

# Upload directories paths (Opcional - substitua se quiser salvar em pastas específicas no host Windows local)
# FACEBOOK_LEADS_DIR=C:\Caminho\Para\leads_facebook
# PITCHYES_CALLS_DIR=C:\Caminho\Para\chamadas_pitchyes
