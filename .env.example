# API Configuration
PORT=8000
HOST=0.0.0.0
DEBUG=False

# REQUIRED — Gere uma chave segura com:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=sua_chave_secreta_aqui_para_producao_gerada

# Caminho do banco de dados dentro do container Docker
DB_PATH=/app/Database/leads.db

# Diretórios de upload (dentro do container Docker — mapeado pelo volume ./Database:/app/Database)
FACEBOOK_LEADS_DIR=/app/Database/leads_facebook
PITCHYES_CALLS_DIR=/app/Database/chamadas_pitchyes
SCRIPT_PATH=/app/Database/build_database.py

# Databricks Configuration (opcional — deixe como está se não for usar)
DATABRICKS_HOST=https://your-databricks-instance.cloud.databricks.com
DATABRICKS_TOKEN=dapi...
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/...

# Meta / Facebook CRM Configuration (opcional — deixe como está se não for usar)
META_ACCESS_TOKEN=EAAB...
META_CRM_PAGE_ID=1234567890
META_APP_SECRET=your_app_secret

# CORS — OBRIGATÓRIO em produção: substitua pelo domínio real
# Sem isso, o backend aceita apenas origens localhost (inseguro em produção)
CORS_ORIGINS=https://seudominio.com

# Backup automático do SQLite
BACKUP_DIR=/app/Database/backups
BACKUP_KEEP_DAYS=30

# Master User Configuration (Criado automaticamente se a tabela de usuários estiver vazia)
MASTER_USER_EMAIL=master@master.com
MASTER_USER_PASSWORD=MasterPassword123!
MASTER_USER_NAME=Usuario Master
